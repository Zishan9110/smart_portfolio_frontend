# The Vite dev server proxies /api requests to the backend (see vite.config.js),
# so no environment variables are strictly required for local development.
#
# If you deploy the frontend separately from the backend (e.g. Vercel + Render),
# uncomment and set this to your backend's public URL, then update src/api/axiosClient.js
# to use it as the baseURL instead of the relative '/api' path.
# VITE_API_URL=https://your-backend-domain.com/api
